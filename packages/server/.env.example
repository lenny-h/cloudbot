# ==================================================
# CORE CONFIGURATION
# ==================================================

# The base URL for Better Auth (e.g., http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of trusted origins for CORS
ALLOWED_ORIGINS="http://localhost:3000"

# Comma-separated list of admin user IDs
ADMIN_USER_IDS=""

# ==================================================
# FEATURE FLAGS
# ==================================================

# Enable email/password signup (true/false)
ENABLE_EMAIL_SIGNUP="true"

# Enable OAuth login providers (true/false)
ENABLE_OAUTH_LOGIN="false"

# Enable SSO authentication (true/false)
ENABLE_SSO="false"

# ==================================================
# EMAIL CONFIGURATION
# ==================================================

# Optional: Restrict signups to specific email domains (comma-separated)
# Leave empty to allow all domains
ALLOWED_EMAIL_DOMAINS=""

# ==================================================
# OAUTH PROVIDERS (Required if ENABLE_OAUTH_LOGIN=true)
# ==================================================

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitLab OAuth
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# ==================================================
# SSO CONFIGURATION (Required if ENABLE_SSO=true)
# ==================================================

# SSO Domain (e.g., example.com)
SSO_DOMAIN=

# SSO Provider ID (e.g., keycloak)
SSO_PROVIDER_ID=

# SSO Client Credentials
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# SSO Endpoints
SSO_ISSUER=
SSO_DISCOVERY_ENDPOINT=
SSO_AUTHORIZATION_ENDPOINT=
SSO_TOKEN_ENDPOINT=
SSO_JWKS_ENDPOINT=

# ==================================================
# DATABASE CONFIGURATION
# ==================================================

# Cloudflare D1 Database Credentials (required to run migrations with drizzle-kit)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""

# ==================================================
# ENVIRONMENT
# ==================================================

# Environment mode (development/production)
NODE_ENV="development"
