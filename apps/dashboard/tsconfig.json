{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@workspace/api-routes/*": ["../../packages/api-routes/dist/*"],
      "@workspace/server/*": ["../../packages/server/dist/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
