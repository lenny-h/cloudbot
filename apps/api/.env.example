# ==================================================
# CORE CONFIGURATION
# ==================================================

# Environment mode (development/production)
NODE_ENV="development"

# The base URL for Better Auth
BETTER_AUTH_URL="http://localhost:3002"

# Better Auth secret key
# Can be generated by running 'openssl rand -hex 32' in the terminal (MacOS/Linux) or
# '[byte[]]$bytes = New-Object byte[] 16; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); ($bytes | ForEach-Object { $_.ToString("x2") }) -join ""' in PowerShell (Windows)
BETTER_AUTH_SECRET="your-better-auth-secret"

# Comma-separated list of user IDs who should have admin privileges
ADMIN_USER_IDS=""

# Comma-separated list of trusted origins for CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ==================================================
# FEATURE FLAGS
# ==================================================

# Enable email/password signup (true/false)
ENABLE_EMAIL_SIGNUP="true"

# Enable OAuth login providers (true/false)
ENABLE_OAUTH_LOGIN="false"

# Enable SSO authentication (true/false)
ENABLE_SSO="false"

# ==================================================
# EMAIL CONFIGURATION
# ==================================================

# Optional: Restrict signups to specific email domains (comma-separated)
# Example: "example.com,mycompany.com". Leave empty to allow all domains
ALLOWED_EMAIL_DOMAINS=""

# Email service configuration (Required if ENABLE_EMAIL_SIGNUP=true)
RESEND_SENDER_EMAIL="your-resend-sender-email"
RESEND_API_KEY="your-resend-api-key"

# ==================================================
# OAUTH PROVIDERS (Required if ENABLE_OAUTH_LOGIN=true)
# ==================================================

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# GitLab OAuth
GITLAB_CLIENT_ID="your-gitlab-client-id"
GITLAB_CLIENT_SECRET="your-gitlab-client-secret"

# ==================================================
# SSO CONFIGURATION (Required if ENABLE_SSO=true)
# ==================================================

# SSO Domain (e.g., example.com)
SSO_DOMAIN="example.com"

# SSO Provider ID (e.g., keycloak-test)
SSO_PROVIDER_ID="keycloak-test"

# SSO Client Credentials
SSO_CLIENT_ID="test-client"
SSO_CLIENT_SECRET="your-sso-client-secret"

# SSO Endpoints
SSO_ISSUER="http://localhost:8080/realms/test-realm"
SSO_DISCOVERY_ENDPOINT="http://localhost:8080/realms/test-realm/.well-known/openid-configuration"
SSO_AUTHORIZATION_ENDPOINT="http://localhost:8080/realms/test-realm/protocol/openid-connect/auth"
SSO_TOKEN_ENDPOINT="http://localhost:8080/realms/test-realm/protocol/openid-connect/token"
SSO_JWKS_ENDPOINT="http://localhost:8080/realms/test-realm/protocol/openid-connect/certs"

# ==================================================
# APPLICATION CONFIGURATION
# ==================================================

# Available LLM models configuration
NEXT_PUBLIC_LLM_MODELS='[{"name":"gpt-4o","label":"GPT-4o","provider":"openai","description":"Powerful model with fast response times","images":true,"pdfs":true,"reasoning":false},{"name":"gpt-5","label":"GPT-5","provider":"openai","description":"Most capable model","images":true,"pdfs":true,"reasoning":false}]'

# Encryption key for encrypting sensitive data (must be 32 characters for AES-256)
# Can be generated by running 'openssl rand -hex 32' in the terminal (MacOS/Linux) or
# '[byte[]]$bytes = New-Object byte[] 16; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); ($bytes | ForEach-Object { $_.ToString("x2") }) -join ""' in PowerShell (Windows)
ENCRYPTION_KEY="your-encryption-key"

# ==================================================
# STORAGE CONFIGURATION
# ==================================================

# Cloudflare R2 configuration (required for signed URLs)
R2_ENDPOINT="https://<your-account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_ACCESS_KEY_ID="your-cloudflare-access-key-id"
CLOUDFLARE_SECRET_ACCESS_KEY="your-cloudflare-secret-access-key"

# ==================================================
# LLM PROVIDERS
# ==================================================

# Vercel AI Gateway
AI_GATEWAY_API_KEY="your-vercel-ai-gateway-api-key"

# Anthropic (only one of the following is required)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_AUTH_TOKEN="your-anthropic-auth-token"

# Amazon Bedrock
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="your-aws-region"

# Azure
AZURE_RESOURCE_NAME="your-azure-resource-name"
AZURE_API_KEY="your-azure-api-key"

# Google Vertex AI
GOOGLE_VERTEX_PROJECT="your-google-vertex-project-id"
GOOGLE_VERTEX_LOCATION="your-google-vertex-location"
GOOGLE_CLIENT_EMAIL="your-google-client-email"
GOOGLE_PRIVATE_KEY="your-google-private-key"
GOOGLE_PRIVATE_KEY_ID="your-google-private-key-id"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# ==================================================
# SEARCH CONFIGURATION
# ==================================================

# Search Provider
# Options: "vercel-ai-perplexity", "vercel-ai-parallel", "anthropic", "azure", "google", 
# "google-enterprise", "openai", "exalabs", "parallel", "tavily"
# Note: 'vercel-ai-perplexity' and 'vercel-ai-parallel' only work with vercel-ai-gateway as the LLM provider
SEARCH_PROVIDER="google"

# ==================================================
# SEARCH API KEYS (Required for third-party search providers)
# ==================================================

EXA_API_KEY="your-exalabs-api-key"
PARALLEL_API_KEY="your-parallel-api-key"
TAVILY_API_KEY="your-tavily-api-key"

# ==================================================
# MODEL SELECTION
# ==================================================

# Index of the model to use for different tasks (from NEXT_PUBLIC_LLM_MODELS)
TITLE_MODEL_IDX="0"
ARTIFACT_MODEL_IDX="0"
WEB_SEARCH_MODEL_IDX="0"
COMPLETION_MODEL_IDX="0"

# Note: If your search provider is 'anthropic', 'azure', 'google', 'google-enterprise' or 'openai',
# the model corresponding to WEB_SEARCH_MODEL_IDX must be from the same provider