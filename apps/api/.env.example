PORT = "3002"

NODE_ENV = "development"

# ==============================
# Authentication configuration
# ==============================

BETTER_AUTH_URL = "http://localhost:3002"
# Can e.g. be generated by running 'openssl rand -hex 32' in the terminal (MacOS/Linux) or
# '[byte[]]$bytes = New-Object byte[] 32; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); ($bytes | ForEach-Object { $_.ToString("x2") }) -join ""' in Powershell (Windows)
BETTER_AUTH_SECRET = "your-better-auth-secret"
ADMIN_USER_IDS = "" # Comma-separated list of user IDs who should have admin privileges

# Enable email/password sign-up
ENABLE_EMAIL_SIGNUP = "true"
# Comma-separated list of allowed email domains for sign-up
# e.g. "example.com,mycompany.com". Leave empty to allow all domains.
ALLOWED_EMAIL_DOMAINS = ""

# Enable OAuth login
ENABLE_OAUTH_LOGIN = "true"
# Not required if ENABLE_OAUTH_LOGIN is "false"
# Google OAuth Configuration
GOOGLE_CLIENT_ID = "your-google-client-id"
GOOGLE_CLIENT_SECRET = "your-google-client-secret"
# GitHub OAuth Configuration
GITHUB_CLIENT_ID = "your-github-client-id"
GITHUB_CLIENT_SECRET = "your-github-client-secret"
# Gitlab OAuth Configuration
GITLAB_CLIENT_ID = "your-gitlab-client-id"
GITLAB_CLIENT_SECRET = "your-gitlab-client-secret"

# SSO Configuration
ENABLE_SSO = "false"
# Not required if ENABLE_SSO is "false"
SSO_DOMAIN = "example.com"
SSO_PROVIDER_ID = "keycloak-test"
SSO_CLIENT_ID = "test-client"
SSO_CLIENT_SECRET = "your-sso-client-secret"
SSO_ISSUER = "http://localhost:8080/realms/test-realm"
SSO_AUTHORIZATION_ENDPOINT = "http://localhost:8080/realms/test-realm/protocol/openid-connect/auth"
SSO_DISCOVERY_ENDPOINT = "http://localhost:8080/realms/test-realm/.well-known/openid-configuration"
SSO_TOKEN_ENDPOINT = "http://localhost:8080/realms/test-realm/protocol/openid-connect/token"
SSO_JWKS_ENDPOINT = "http://localhost:8080/realms/test-realm/protocol/openid-connect/certs"

# Mail configuration
# Not required if ENABLE_EMAIL_SIGNUP is "false"
RESEND_SENDER_EMAIL = "your-resend-sender-email"
RESEND_API_KEY = "your-resend-api-key"

# ==============================
# Application configuration
# ==============================

BASE_URL = "http://localhost:3000"
ALLOWED_ORIGINS = "http://localhost:3000,http://localhost:3001"

# Encryption key for encrypting sensitive data
# Can e.g. be generated by running 'openssl rand -hex 32' in the terminal (MacOS/Linux) or
# '[byte[]]$bytes = New-Object byte[] 32; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); ($bytes | ForEach-Object { $_.ToString("x2") }) -join ""' in Powershell (Windows)
ENCRYPTION_KEY = "your-encryption-key" # Must be 32 characters long for AES-256

# Cloudflare R2 configuration (required for signed urls)
R2_ENDPOINT = "https://<your-account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_ACCESS_KEY_ID = "your-cloudflare-access-key-id"
CLOUDFLARE_SECRET_ACCESS_KEY = "your-cloudflare-secret-access-key"

# ==============================
# LLM and search provider configuration
# ==============================

# Vercel AI Gateway
AI_GATEWAY_API_KEY = "your-vercel-ai-gateway-api-key"

# Anthropic
# Only one of the following is required
ANTHROPIC_API_KEY = "your-anthropic-api-key"
ANTHROPIC_AUTH_TOKEN = "your-anthropic-auth-token"

# Amazon Bedrock
AWS_ACCESS_KEY_ID= "your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY= "your-aws-secret-access-key"
AWS_REGION= "your-aws-region"

# Azure
AZURE_RESOURCE_NAME = "your-azure-resource-name"
AZURE_API_KEY = "your-azure-api-key"

# Google Vertex AI
GOOGLE_VERTEX_PROJECT = "your-google-vertex-project-id"
GOOGLE_VERTEX_LOCATION = "your-google-vertex-location"
GOOGLE_CLIENT_EMAIL = "your-google-client-email"
GOOGLE_PRIVATE_KEY = "your-google-private-key"
GOOGLE_PRIVATE_KEY_ID = "your-google-private-key-id" # Optional

# OpenAI
OPENAI_API_KEY = "your-openai-api-key"

# Search Provider
# Options: "vercel-ai-perplexity", "vercel-ai-parallel", "anthropic", "azure", "google", "google-enterprise", 
# "openai", "exalabs", "parallel", "tavily"
# 'vercel-ai-perplexity' and 'vercel-ai-parallel' only work with vercel-ai-gateway as the LLM provider 
SEARCH_PROVIDER = "google"

# Search API keys (only required for third-party search providers)
EXA_API_KEY = "your-exalabs-api-key"
PARALLEL_API_KEY = "your-parallel-api-key"
TAVILY_API_KEY = "your-tavily-api-key"

# Model selection
TITLE_MODEL_IDX = "0"
ARTIFACT_MODEL_IDX = "0"
WEB_SEARCH_MODEL_IDX = "0" # If your search provider is one of 'anthropic', 'azure', 'google', 'google-enterprise' or 'openai', the model corresponding to WEB_SEARCH_MODEL_IDX must be from the same provider
COMPLETION_MODEL_IDX = "0"