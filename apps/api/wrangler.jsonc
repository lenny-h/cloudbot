{
    "name": "cloudbot-api",
    "main": "src/index.ts",
    "compatibility_date": "2025-04-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "d1_databases": [
        {
            "binding": "BINDING_NAME",
            "database_name": "YOUR_DB_NAME",
            "database_id": "YOUR_DB_ID",
            "migrations_dir": "./../packages/server/src/drizzle/migrations"
        }
    ]
}
